# APT custom aliases
alias aup="sudo nala update && sudo apt upgrade -y"
alias ain="sudo nala install -y"
alias arm="sudo apt remove -y"
alias apr="sudo apt purge"
alias asr="sudo apt search"

# DNF custom aliases
alias dup="sudo dnf update && sudo dnf upgrade -y"
alias din="sudo dnf install -y"
alias drm="sudo dnf remove -y"
alias dsr="sudo dnf search"

# Pacman custom aliases
alias pup="sudo pacman -Syuu --noconfirm"
alias pin="sudo pacman -S --noconfirm"
alias prm="sudo pacman -Rsc --noconfirm"
alias psr="sudo pacman -Ss"
alias paup="paru -Syu --noconfirm"
alias pain="paru -S --noconfirm"
alias parm="paru -Rsc --noconfirm"
alias pasr="paru -Ss"

# Flatpak custom aliases
alias fup="flatpak update -y"
alias fin="flatpak install flathub -y"
alias frm="flatpak remove -y"
alias fsr="flatpak search"

# Monitor DDCutil
alias m10="ddcutil setvcp 10 10 --display 1"
alias m20="ddcutil setvcp 10 20 --display 1"
alias m30="ddcutil setvcp 10 30 --display 1"
alias m40="ddcutil setvcp 10 40 --display 1"
alias m50="ddcutil setvcp 10 50 --display 1"
alias m60="ddcutil setvcp 10 60 --display 1"
alias m70="ddcutil setvcp 10 70 --display 1"
alias m80="ddcutil setvcp 10 80 --display 1"
alias m90="ddcutil setvcp 10 90 --display 1"
alias m100="ddcutil setvcp 10 100 --display 1"
